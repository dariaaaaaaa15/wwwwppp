import sys

from PyQt5.QtWidgets import (
    QApplication, QMainWindow, QWidget, QLabel, QPushButton,
    QLineEdit, QTableWidget, QTableWidgetItem, QVBoxLayout,
    QHBoxLayout, QMessageBox, QTextEdit, QHeaderView
)

from matplotlib.backends.backend_qt5agg import FigureCanvasQTAgg as FigureCanvas
from matplotlib.figure import Figure


class Flight:
    licznik_id = 1

    def __init__(self, model_drona, czas_minuty, data):
        self.id = Flight.licznik_id
        Flight.licznik_id += 1

        self.model_drona = model_drona
        self.czas_minuty = int(czas_minuty)
        self.data = data

    def __str__(self):
        return f"{self.id}. {self.model_drona} | {self.czas_minuty} min | {self.data}"


class DroneManager:
    def __init__(self):
        self.loty = []

    def dodaj_lot(self, model_drona, czas_minuty, data):
        lot = Flight(model_drona, czas_minuty, data)
        self.loty.append(lot)

    def pobierz_wszystkie_loty(self):
        return self.loty

    def oblicz_calkowity_nalot(self, model_drona):
        suma = 0

        for lot in self.loty:
            if lot.model_drona == model_drona:
                suma += lot.czas_minuty

        return suma

    def zwracaj_wynik_w_godzinach(self, minuty):
        return minuty / 60

    def pobierz_slownik_nalotu(self):
        slownik = {}

        for lot in self.loty:
            if lot.model_drona in slownik:
                slownik[lot.model_drona] += lot.czas_minuty
            else:
                slownik[lot.model_drona] = lot.czas_minuty

        for model in slownik:
            slownik[model] = slownik[model] / 60

        return slownik


class DroneApp(QMainWindow):
    def __init__(self):
        super().__init__()

        self.manager = DroneManager()

        self.setWindowTitle("Aplikacja do rejestrowania lotów dronów")
        self.setGeometry(300, 200, 1000, 750)

        self.model_input = QLineEdit()
        self.model_input.setPlaceholderText("Model drona, np. DJI Mavic 3")

        self.czas_input = QLineEdit()
        self.czas_input.setPlaceholderText("Czas lotu w minutach")

        self.data_input = QLineEdit()
        self.data_input.setPlaceholderText("Data lotu, np. 2026-06-19")

        self.model_raport_input = QLineEdit()
        self.model_raport_input.setPlaceholderText("Model drona do sprawdzenia nalotu")

        self.przycisk_dodaj = QPushButton("Dodaj lot")
        self.przycisk_dodaj.clicked.connect(self.dodaj_lot)

        self.przycisk_nalot = QPushButton("Oblicz nalot modelu")
        self.przycisk_nalot.clicked.connect(self.oblicz_nalot_modelu)

        self.przycisk_raport = QPushButton("Pokaż raport")
        self.przycisk_raport.clicked.connect(self.pokaz_raport)

        self.tabela = QTableWidget()
        self.tabela.setColumnCount(4)
        self.tabela.setHorizontalHeaderLabels([
            "ID",
            "Model drona",
            "Czas lotu [min]",
            "Data"
        ])
        self.tabela.horizontalHeader().setSectionResizeMode(QHeaderView.Stretch)

        self.raport_text = QTextEdit()
        self.raport_text.setReadOnly(True)

        self.figure = Figure()
        self.canvas = FigureCanvas(self.figure)

        formularz = QHBoxLayout()
        formularz.addWidget(self.model_input)
        formularz.addWidget(self.czas_input)
        formularz.addWidget(self.data_input)
        formularz.addWidget(self.przycisk_dodaj)

        raport_layout = QHBoxLayout()
        raport_layout.addWidget(self.model_raport_input)
        raport_layout.addWidget(self.przycisk_nalot)
        raport_layout.addWidget(self.przycisk_raport)

        layout = QVBoxLayout()
        layout.addWidget(QLabel("System rejestrowania czasu lotów dronów"))
        layout.addLayout(formularz)
        layout.addLayout(raport_layout)
        layout.addWidget(self.tabela)
        layout.addWidget(QLabel("Raport:"))
        layout.addWidget(self.raport_text)
        layout.addWidget(self.canvas)

        kontener = QWidget()
        kontener.setLayout(layout)
        self.setCentralWidget(kontener)

        self.setStyleSheet("""
            QMainWindow {
                background-color: #f0f4f8;
            }

            QLabel {
                font-size: 14px;
                font-weight: bold;
            }

            QLineEdit {
                background-color: white;
                border: 1px solid gray;
                border-radius: 6px;
                padding: 6px;
                font-size: 13px;
            }

            QPushButton {
                background-color: #2d89ef;
                color: white;
                border-radius: 8px;
                padding: 8px;
                font-weight: bold;
            }

            QPushButton:hover {
                background-color: #1b5fa7;
            }

            QTableWidget {
                background-color: white;
                gridline-color: #cccccc;
                font-size: 13px;
            }

            QHeaderView::section {
                background-color: #2d89ef;
                color: white;
                padding: 5px;
                font-weight: bold;
            }

            QTextEdit {
                background-color: white;
                border: 1px solid gray;
                border-radius: 6px;
                padding: 6px;
                font-size: 13px;
            }
        """)

        self.dodaj_dane_testowe()
        self.odswiez_tabele()
        self.odswiez_wykres()

    def dodaj_dane_testowe(self):
        self.manager.dodaj_lot("DJI Mavic 3", 120, "2026-06-19")
        self.manager.dodaj_lot("DJI Mavic 3", 150, "2026-06-20")
        self.manager.dodaj_lot("Autel Evo 2", 90, "2026-06-21")
        self.manager.dodaj_lot("Autel Evo 2", 60, "2026-06-22")

    def dodaj_lot(self):
        model = self.model_input.text()
        czas = self.czas_input.text()
        data = self.data_input.text()

        if model == "" or czas == "" or data == "":
            QMessageBox.warning(
                self,
                "Błąd",
                "Uzupełnij wszystkie pola."
            )
            return

        try:
            self.manager.dodaj_lot(model, czas, data)

            self.model_input.clear()
            self.czas_input.clear()
            self.data_input.clear()

            self.odswiez_tabele()
            self.odswiez_wykres()
            self.pokaz_raport()

        except ValueError:
            QMessageBox.warning(
                self,
                "Błąd danych",
                "Czas lotu musi być liczbą całkowitą."
            )

    def odswiez_tabele(self):
        loty = self.manager.pobierz_wszystkie_loty()

        self.tabela.setRowCount(len(loty))

        for i, lot in enumerate(loty):
            self.tabela.setItem(i, 0, QTableWidgetItem(str(lot.id)))
            self.tabela.setItem(i, 1, QTableWidgetItem(lot.model_drona))
            self.tabela.setItem(i, 2, QTableWidgetItem(str(lot.czas_minuty)))
            self.tabela.setItem(i, 3, QTableWidgetItem(lot.data))

    def oblicz_nalot_modelu(self):
        model = self.model_raport_input.text()

        if model == "":
            QMessageBox.warning(
                self,
                "Błąd",
                "Podaj model drona."
            )
            return

        minuty = self.manager.oblicz_calkowity_nalot(model)
        godziny = self.manager.zwracaj_wynik_w_godzinach(minuty)

        self.raport_text.setText(
            f"Całkowity nalot dla modelu {model}: {godziny:.2f} godzin"
        )

    def pokaz_raport(self):
        slownik = self.manager.pobierz_slownik_nalotu()

        tekst = "Raport całkowitego nalotu według modeli:\n\n"

        if len(slownik) == 0:
            tekst += "Brak danych."
        else:
            for model in slownik:
                tekst += f"{model}: {slownik[model]:.2f} godzin\n"

        self.raport_text.setText(tekst)

    def odswiez_wykres(self):
        dane = self.manager.pobierz_slownik_nalotu()

        self.figure.clear()
        ax = self.figure.add_subplot(111)

        if dane:
            ax.bar(dane.keys(), dane.values())
            ax.set_title("Całkowity nalot według modeli dronów")
            ax.set_xlabel("Model drona")
            ax.set_ylabel("Nalot [godziny]")
        else:
            ax.set_title("Brak danych do wykresu")
            ax.set_xlabel("Model drona")
            ax.set_ylabel("Nalot [godziny]")

        self.figure.tight_layout()
        self.canvas.draw()


if __name__ == "__main__":
    app = QApplication(sys.argv)
    okno = DroneApp()
    okno.show()
    sys.exit(app.exec_())
